---
import { Image } from 'astro:assets';

import { programs } from '../data/programs';

import { ui } from '../i18n/ui';
const lang = (Astro.currentLocale || 'it') as keyof typeof ui;
const t = ui[lang] as typeof ui['it'];

---

<style>
    .programs-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        margin: 40px auto;
        padding: 20px;
        border-radius: 16px;
        background: var(--card-gradient);
        width: fit-content;
        align-items: center;
    }

    .program-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 120px;
    }

    .program-icon {
        width: 60px;
        height: 60px;
        margin-bottom: 10px;
        object-fit: contain;
    }

    h3 {
        font-size: 1rem;
        text-align: center;
        color: white;
        font-family: var(--font-base);
    }

    h2 {
        color: var(--primary-color);
        margin: 3rem 1rem 1.5rem;
        text-align: center;
        font-size: 2rem;
        font-family: var(--font-base);
    }

</style>

<h2>{t.programs.description}</h2>

<div class="programs-container">
    {programs.map((program) => (
        <div class="program-box">
            <Image src={program.img} alt={program.name} class="program-icon" />
            <h3>{program.name}</h3>
        </div>
    ))}
</div>


