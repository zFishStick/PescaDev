<section class="projects-viewer">
    <h2>{t.projects.importantProjects}</h2>
        <a href={projects[0].link} target="_blank" class="project-card">
        <Image src={projects[0].img} alt={projects[0].name} loading="lazy"/>
        <p class="description">{projects[0].description[lang]}</p>
    </a>
</section>

<style>

    .projects-viewer {
        gap: 2rem;
        font-family: var(--font-base);
        padding-bottom: 2rem;

        h2 {
            color: var(--primary-color);
            margin: 3rem 1rem 1.5rem;
            text-align: center;
            font-size: 2rem;
        }

        .description {
            font-size: 1.6rem;
        }

        .project-card {
            padding: 1rem;
            padding-top: 0;
            background: var(--card-gradient);
            color: white;
            box-shadow: 0 14px 32px rgba(184, 85, 46, 0.35);
            border: 2px solid var(--tertiary-color);
            transition: transform 0.3s ease, box-shadow 0.3s ease;

            p {
                margin: 0.5rem 0;
            }
        }

        .project-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(184, 85, 46, 0.45);
        }

        .project-card {
            width: 50%;
            margin: 0 auto;
            text-align: center;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
        }

        .project-card h3 {
            margin: 0;
            font-size: 3rem;
        }

        .project-card img {
            border-radius: 8px;
            width: 200px;
            height: auto;
            margin-top: 1rem;
        }

        .project-card p {
            font-size: 1.5rem;
        }

        .projects-viewer a {
            display: inline-block;
            padding: 0.5rem 1rem;
            background-color: var(--secondary-color);
            color: white;
            text-decoration: none;
            border-radius: 4px;
            width: -webkit-fill-available;
            text-align: center;
            font-weight: bold;
            transition: all 0.3s ease;
            margin-top: 1rem;
            transition: all 0.3s ease;
        }

        .projects-viewer a:hover {
            transform: scale(1.05);
        }
    }


    @media (max-width: 480px) {
        .projects-viewer {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2rem;
                font-family: var(--font-base);
                height: 80%;

                h2 {
                    color: var(--primary-color);
                    text-align: center;
                    font-size: 1.2rem;
                    margin: 0 1rem;
                    width: 300px;
                }

            .project-card {
                background: var(--card-gradient);
                color: white;
                width: 90%;
                border: 2px solid var(--tertiary-color);
                box-shadow: 0 14px 32px rgba(184, 85, 46, 0.35);

                h3 {
                    font-size: 2rem;
                    padding-left: 0.1rem;
                }

                p {
                    margin: 0.5rem 0;
                    font-size: 1rem;
                }
            }

            .project-card {
                padding: 1rem;
                margin: 0 auto;
                text-align: center;
                border-radius: 16px;
                display: flex;
                flex-direction: column;
                align-items: center;
                text-decoration: none;
                transition: all 0.3s ease;

                img {
                    width: 50%;
                    height: auto;
                }
            }

            .project-card h3 {
                margin: 0;
            }

            .project-card img {
                border-radius: 8px;
            }

            .projects-viewer a {
                display: inline-block;
                padding: 0.5rem 1rem;
                background-color: var(--secondary-color);
                color: white;
                text-decoration: none;
                transition: all 0.3s ease;
                border-radius: 4px;
                width: -webkit-fill-available;
                text-align: center;
                font-weight: bold;
                margin-top: 1rem;
                text-decoration: none;
            }

            .projects-viewer a:hover {
                transform: scale(1.05);
            }
    }
}

</style>