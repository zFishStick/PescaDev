---
import {Image} from 'astro:assets';
import { projects } from '../data//projects';

import '../styles/global.css';

import { ui } from '../i18n/ui';
const lang = (Astro.currentLocale || 'it') as keyof typeof ui;
const t = ui[lang] as typeof ui['it'];
